// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  settings UserSettings?
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String?
  fileHash      String        @unique
  fileName      String
  filePath      String?
  vendor        String?
  vendorDomain  String?
  logoUrl       String?
  logoBgColor   String?
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  lineItems     Json          @default("[]")
  subtotal      Decimal?      @db.Decimal(12, 2)
  tax           Decimal?      @db.Decimal(12, 2)
  total         Decimal?      @db.Decimal(12, 2)
  currency      String?       @default("GBP")
  confidence    Json          @default("{}")
  editedFields  String[]
  status        InvoiceStatus @default(PROCESSING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([fileHash])
}

model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  exportFormat   String   @default("csv")
  visibleColumns Json     @default("[\"vendor\",\"invoiceNumber\",\"invoiceDate\",\"dueDate\",\"total\",\"currency\",\"status\"]")
  darkMode       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  PROCESSING
  COMPLETE
  ERROR
  AWAITING_PASSWORD
}
