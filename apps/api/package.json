{
  "name": "@financio/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.7",
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.0.3",
    "@financio/types": "workspace:*",
    "@prisma/client": "^6.12.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "heic-convert": "^2.1.0",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/pdf-parse": "^1.1.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
